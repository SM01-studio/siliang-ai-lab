[Unit]
Description=Siliang AI LAB - AI Writer Backend (Port 5001)
After=network.target

[Service]
User=root
WorkingDirectory=/www/siliang-ai-lab/writer
ExecStart=/www/siliang-ai-lab/venv/bin/gunicorn --bind 127.0.0.1:5001 --workers 2 --timeout 300 --worker-class gevent app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
